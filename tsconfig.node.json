{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "build/**/*.ts",
    "vite.client.config.ts",
    "vite.server.config.ts",
    "vitest.config.ts"
  ],
  "exclude": ["build/**/*.test.ts"]
}
